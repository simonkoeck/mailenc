{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mailenc",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "routes": [
    { "pattern": "mailenc.org", "custom_domain": true },
    { "pattern": "www.mailenc.org", "custom_domain": true }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": [
      "/api/*",
      "/bot-key.asc",
      "/.well-known/openpgpkey/*"
    ]
  },
  "vars": {
    "EMAIL_DOMAIN": "mailenc.org",
    "BOT_LOCALPART": "echo",
    "BOT_PGP_PUBLIC": "-----BEGIN PGP PUBLIC KEY BLOCK-----\n\nxjMEagbRIRYJKwYBBAHaRw8BAQdAfwuMYGhpWpWaa9sTnYWqtGm7AhoAeOSv\nquuDZOToMJ/NLEVtYWlsIEVuY3J5cHRpb24gVGVzdCBCb3QgPGVjaG9AbWFp\nbGVuYy5vcmc+wsATBBMWCgCFBYJqBtEhAwsJBwkQ4kMwlpe/EdlFFAAAAAAA\nHAAgc2FsdEBub3RhdGlvbnMub3BlbnBncGpzLm9yZ30QAf7PvwrTydfcyLjv\nnLiUx71tZKVQTCPERNbvDgJNBRUKCA4MBBYAAgECGQECmwMCHgEWIQQBJlSU\nXarpMmM87aXiQzCWl78R2QAAmvsBAKbJi2B+d3wt0qyTIUqh0r/YyhwdEIko\nWyohHaPI0uqdAP9Gs+CWKVJa6OUrZm7EkyH2Msx8GELhVKlJEmXTyPVdB844\nBGoG0SESCisGAQQBl1UBBQEBB0As1o9tkoxiy7xaF4GJjiTeHKoe7opoGRcX\nqyYcO6QLeQMBCAfCvgQYFgoAcAWCagbRIQkQ4kMwlpe/EdlFFAAAAAAAHAAg\nc2FsdEBub3RhdGlvbnMub3BlbnBncGpzLm9yZ/7Fl+fWcHPCUYK3XmfiHsRb\ncIbUgisAEFHKe6aiGKmCApsMFiEEASZUlF2q6TJjPO2l4kMwlpe/EdkAALu1\nAP4iTcjXJzizufvBlkt6tiCGjx69fh+MN4EUnkRTIFCnGAEA2pUdRU7roUI9\n88n/UxTtAbqjFz254i/8db6EpkQXBQ0=\n=mSz/\n-----END PGP PUBLIC KEY BLOCK-----"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSION",
        "class_name": "SessionDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
